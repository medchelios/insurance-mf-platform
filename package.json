{
  "name": "insurance-mf-platform",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel -m -C apps-mf/apps dev",
    "dev:host": "pnpm --filter host -C apps-mf/apps dev",
    "dev:mfe1": "pnpm --filter mfe1 -C apps-mf/apps dev",
    "dev:mfe2": "pnpm --filter mfe2 -C apps-mf/apps dev",
    "dev:api": "pnpm -C bff-mf/api dev",
    "build": "pnpm -r -C apps-mf/apps build",
    "start": "pnpm -r -C apps-mf/apps preview"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}